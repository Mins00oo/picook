<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <property name="LOG_PATTERN"
              value="[%d{yyyy-MM-dd HH:mm:ss.SSS}] [%-5level] [%thread] %logger{36} - %msg%n"/>

    <!-- ===== LOCAL 프로필 ===== -->
    <springProfile name="local">
        <property name="LOG_DIR" value="C:/work/logs/picook-backend"/>

        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
            </encoder>
        </appender>

        <!-- Lighthouse 모니터링 수집용 JSON (LogstashEncoder) -->
        <appender name="LIGHTHOUSE_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_DIR}/lighthouse.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_DIR}/lighthouse-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxFileSize>50MB</maxFileSize>
                <maxHistory>7</maxHistory>
                <totalSizeCap>500MB</totalSizeCap>
            </rollingPolicy>
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <customFields>{"service":"picook-backend"}</customFields>
                <includeMdcKeyName>http_method</includeMdcKeyName>
                <includeMdcKeyName>http_path</includeMdcKeyName>
                <includeMdcKeyName>http_status</includeMdcKeyName>
                <includeMdcKeyName>response_time_ms</includeMdcKeyName>
                <includeMdcKeyName>client_ip</includeMdcKeyName>
                <includeMdcKeyName>exception_class</includeMdcKeyName>
                <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
                    <maxDepthPerThrowable>30</maxDepthPerThrowable>
                    <shortenedClassNameLength>36</shortenedClassNameLength>
                    <rootCauseFirst>true</rootCauseFirst>
                </throwableConverter>
            </encoder>
        </appender>

        <!-- Lighthouse 수집 전용 로거 -->
        <logger name="lighthouse_access" level="INFO" additivity="false">
            <appender-ref ref="LIGHTHOUSE_FILE"/>
        </logger>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="LIGHTHOUSE_FILE"/>
        </root>

        <logger name="com.picook" level="DEBUG"/>
        <logger name="org.hibernate.SQL" level="DEBUG"/>
        <logger name="org.hibernate.type.descriptor.sql.BasicBinder" level="TRACE"/>
    </springProfile>

    <!-- ===== PROD 프로필 ===== -->
    <springProfile name="prod">
        <property name="LOG_DIR" value="/var/log/picook"/>

        <!-- 콘솔: WARN 이상만 -->
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
                <level>WARN</level>
            </filter>
            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
            </encoder>
        </appender>

        <!-- 1) app.log — INFO 이상, 일별 롤링, 30일 보관, 최대 1GB -->
        <appender name="APP_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_DIR}/app.log</file>
            <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
                <level>INFO</level>
            </filter>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_DIR}/app-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxFileSize>50MB</maxFileSize>
                <maxHistory>30</maxHistory>
                <totalSizeCap>1GB</totalSizeCap>
            </rollingPolicy>
            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
            </encoder>
        </appender>

        <!-- 2) error.log — ERROR만, 일별 롤링, 90일 보관 -->
        <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_DIR}/error.log</file>
            <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
                <level>ERROR</level>
            </filter>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_DIR}/error-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxFileSize>50MB</maxFileSize>
                <maxHistory>90</maxHistory>
                <totalSizeCap>500MB</totalSizeCap>
            </rollingPolicy>
            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
            </encoder>
        </appender>

        <!-- 3) sql.log — Hibernate SQL 전용, 기본 OFF, 7일 보관 -->
        <appender name="SQL_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_DIR}/sql.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_DIR}/sql-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxFileSize>50MB</maxFileSize>
                <maxHistory>7</maxHistory>
                <totalSizeCap>500MB</totalSizeCap>
            </rollingPolicy>
            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
            </encoder>
        </appender>

        <!-- 4) perf.log — 성능 로그 전용, 30일 보관 -->
        <appender name="PERF_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_DIR}/perf.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_DIR}/perf-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxFileSize>50MB</maxFileSize>
                <maxHistory>30</maxHistory>
                <totalSizeCap>500MB</totalSizeCap>
            </rollingPolicy>
            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
            </encoder>
        </appender>

        <!-- SQL 로거: 기본 OFF, 필요 시 런타임 활성화 -->
        <logger name="org.hibernate.SQL" level="OFF" additivity="false">
            <appender-ref ref="SQL_FILE"/>
        </logger>
        <logger name="org.hibernate.type.descriptor.sql.BasicBinder" level="OFF" additivity="false">
            <appender-ref ref="SQL_FILE"/>
        </logger>

        <!-- 성능 로거: perf.log 전용 -->
        <logger name="com.picook.global.aop" level="INFO" additivity="false">
            <appender-ref ref="PERF_FILE"/>
        </logger>

        <!-- 5) lighthouse.log — Lighthouse 모니터링 수집용 JSON (LogstashEncoder) -->
        <appender name="LIGHTHOUSE_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_DIR}/lighthouse.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_DIR}/lighthouse-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxFileSize>50MB</maxFileSize>
                <maxHistory>7</maxHistory>
                <totalSizeCap>500MB</totalSizeCap>
            </rollingPolicy>
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <customFields>{"service":"picook-backend"}</customFields>
                <includeMdcKeyName>http_method</includeMdcKeyName>
                <includeMdcKeyName>http_path</includeMdcKeyName>
                <includeMdcKeyName>http_status</includeMdcKeyName>
                <includeMdcKeyName>response_time_ms</includeMdcKeyName>
                <includeMdcKeyName>client_ip</includeMdcKeyName>
                <includeMdcKeyName>exception_class</includeMdcKeyName>
                <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
                    <maxDepthPerThrowable>30</maxDepthPerThrowable>
                    <shortenedClassNameLength>36</shortenedClassNameLength>
                    <rootCauseFirst>true</rootCauseFirst>
                </throwableConverter>
            </encoder>
        </appender>

        <!-- Lighthouse 수집 전용 로거 -->
        <logger name="lighthouse_access" level="INFO" additivity="false">
            <appender-ref ref="LIGHTHOUSE_FILE"/>
        </logger>

        <!-- 루트 및 애플리케이션 로거 -->
        <root level="WARN">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="APP_FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </root>

        <logger name="com.picook" level="INFO"/>
        <logger name="org.flywaydb" level="INFO"/>
    </springProfile>

</configuration>
